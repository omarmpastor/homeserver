#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load modules
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/stacks.sh"
source "$SCRIPT_DIR/lib/pull.sh"
source "$SCRIPT_DIR/lib/volumes.sh"
source "$SCRIPT_DIR/lib/checks.sh"

# Order matters
STACKS=("sftpgo" "flame" "gitea" "jellyfin" "media-stack" "metube" "traefik" "dockhand" "syncthing")
# Stacks disabled: nextcloud wireguard joplin filebrowser
VOLUMES=("sftpgo_config" "flame_data" "gitea_data" "jellyfin_data" "qbittorrent_data" "prowlarr_data" "sonarr_data" "radarr_data" "bazarr_data" "jackett_data" "dockhand_data" "syncthing_config")
# Volumes disabled: nextcloud_config nextcloud_custom_apps wireguard_conf wireguard_modules joplin_data filebrowser_config

COMMAND="${1:-}"

usage() {
  cat <<EOF
Uso:
  stackctl <comando>

Comandos:
  up               Levanta toda la infraestructura
  pull             Descarga/actualiza las imágenes
  down             Detiene todos los stacks
  dry-run          Valida la infraestructura sin aplicar cambios
  purge-volumes    Elimina los volúmenes gestionados
  status           Muestra el estado de los contenedores

Ejemplos:
  stackctl up
  stackctl down
  stackctl status
EOF
}

case "$COMMAND" in
  up)
    load_env
    check_structure
    create_volumes
    deploy_stacks
    ;;

  pull)
    load_env
    pull_stacks
    ;;

  down)
    load_env
    down_stacks
    ;;

  dry-run)
    echo "[DRY-RUN] Validando infraestructura..."
    check_structure
    check_volumes
    ;;

  purge-volumes)
    delete_volumes
    ;;
  
  stack)
    STACK_NAME="$2"
    ACTION="$3"

    if [[ -z "$STACK_NAME" || -z "$ACTION" ]]; then
      echo "Uso: $0 stack <nombre_stack> [up|down]"
      exit 1
    fi

    load_env

    case "$ACTION" in
      up)
        echo "Levantando stack: $STACK_NAME"
        # deploy_stack "$STACK_NAME"
        ;;
      down)
        echo "Deteniendo stack: $STACK_NAME"
        # down_stack "$STACK_NAME"
        ;;
      *)
        echo "Acción inválida: $ACTION"
        echo "Uso: $0 stack <nombre_stack> [up|down]"
        exit 1
        ;;
    esac
    ;;

  status)
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    ;;

  *)
    usage
    exit 1
    ;;
esac
