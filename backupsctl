#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load modules
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/backups.sh"
source "$SCRIPT_DIR/lib/checks.sh"
source "$SCRIPT_DIR/lib/volumes.sh"

VOLUMES=("filebrowser_config" "flame_data" "gitea_data" "jellyfin_data" "joplin_data" "qbittorrent_data" "prowlarr_data" "sonarr_data" "radarr_data" "bazarr_data" "jackett_data")

COMMAND="${1:-}"

usage() {
  cat <<EOF
Uso:
  backupsctl <comando>

Comandos:
  up               Levanta el contenedor kopia
  recovery         Recupera el ultimo snapshot desde el repositorio configurado
  dry-run          Valida la infraestructura sin aplicar cambios
  purge-volumes    Elimina los volúmenes gestionados
  status           Muestra el estado

Ejemplos:
  backupsctl up
  backupsctl recovery
EOF
}

case "$COMMAND" in
  up)
    load_env
    create_backup_volumes
    create_kopia_service
    configure_kopia
    ;;

  recovery)
    load_env
    create_backup_volumes
    create_kopia_service
    recovery_latest_snapshot
    ;;

  dry-run)
    echo "[DRY-RUN] Validando ..."
    check_volumes
    ;;

  purge-volumes)
    delete_backup_volumes
    ;;

  status)
    # docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    ;;

  *)
    usage
    exit 1
    ;;
esac