#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load modules
source "$SCRIPT_DIR/lib/env.sh"
source "$SCRIPT_DIR/lib/stacks.sh"
source "$SCRIPT_DIR/lib/pull.sh"
source "$SCRIPT_DIR/lib/volumes.sh"
source "$SCRIPT_DIR/lib/checks.sh"

# Order matters
STACKS=("filebrowser" "flame" "gitea" "jellyfin" "joplin" "media-stack" "metube" "traefik" )
# Stacks disabled: nextcloud wireguard
VOLUMES=("filebrowser_config" "flame_data" "gitea_data" "jellyfin_data" "joplin_data" "qbittorrent_data" "prowlarr_data" "sonarr_data" "radarr_data" "bazarr_data" "jackett_data")
# Volumes disabled: nextcloud_config nextcloud_custom_apps wireguard_conf wireguard_modules

COMMAND="${1:-}"

usage() {
  cat <<EOF
Uso:
  stackctl <comando>

Comandos:
  up               Levanta toda la infraestructura
  pull             Descarga/actualiza las imágenes
  down             Detiene todos los stacks
  dry-run          Valida la infraestructura sin aplicar cambios
  purge-volumes    Elimina los volúmenes gestionados
  status           Muestra el estado de los contenedores

Ejemplos:
  stackctl up
  stackctl down
  stackctl status
EOF
}

case "$COMMAND" in
  up)
    load_env
    check_structure
    create_volumes
    deploy_stacks
    ;;

  pull)
    pull_stacks
    ;;

  down)
    down_stacks
    ;;

  dry-run)
    echo "[DRY-RUN] Validando infraestructura..."
    check_structure
    check_volumes
    ;;

  purge-volumes)
    delete_volumes
    ;;

  status)
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    ;;

  *)
    usage
    exit 1
    ;;
esac
