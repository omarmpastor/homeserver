#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Load modules
source "$SCRIPT_DIR/lib/backups_up.sh"
source "$SCRIPT_DIR/lib/backups_recovery.sh"

VOLUMES=("filebrowser_config" "flame_data" "gitea_data" "jellyfin_data" "joplin_data" "qbittorrent_data" "prowlarr_data" "sonarr_data" "radarr_data" "bazarr_data" "jackett_data")

usage() {
  cat <<EOF
Uso:
  backupsctl <comando>

Comandos:
  up               Levanta el contenedor kopia
  recovery         Recupera el ultimo snapshot desde el repositorio configurado
  dry-run          Valida la infraestructura sin aplicar cambios
  purge-volumes    Elimina los volúmenes gestionados
  status           Muestra el estado

Ejemplos:
  backupsctl up
  backupsctl recovery
EOF
}

case "$COMMAND" in
  up)
    create_volumes
    create_kopia_service
    configure_kopia
    ;;

  recovery)
    ;;

  dry-run)
    echo "[DRY-RUN] Validando ..."
    check_structure
    check_volumes
    ;;

  purge-volumes)
    ;;

  status)
    ;;

  *)
    usage
    exit 1
    ;;
esac